{
  "manifest_version": 3,
  "name": "Tab Organizer",
  "version": "1.0.0",
  "description": "Rename your browser tabs with custom titles and emoji prefixes.",

  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting"
  ],

  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "src/popup-page/index.html",
    "default_icon": {
      "16": "src/assets/icon-16.png",
      "48": "src/assets/icon-48.png",
      "128": "src/assets/icon-128.png"
    }
  },

  "commands": {
    "open-rename-popup": {
      "suggested_key": {
        "default": "Alt+R",
        "mac": "Alt+R"
      },
      "description": "Open the tab rename dialog"
    }
  },

  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  }
}
